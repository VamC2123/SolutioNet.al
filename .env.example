# Copy to `.env` locally. In Vercel, add the same keys (Environment Variables).
# Never commit `.env` with real secrets.

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# OpenAI — optional; without it, AI summaries/embeddings use demo behavior.
# Note: VITE_* is exposed in the browser bundle (OK for small/private sites).
VITE_OPENAI_API_KEY=""
