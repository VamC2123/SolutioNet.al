# Copy this file to `.env` in the project root and fill in real values.
# `.env` is gitignored — never commit secrets.
#
# Get Supabase values: Dashboard → Project Settings → API
#   - Project URL → VITE_SUPABASE_URL
#   - anon public key → VITE_SUPABASE_PUBLISHABLE_KEY
#   - Project reference id (subdomain) → VITE_SUPABASE_PROJECT_ID

VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# "false" = AI/embeddings use demo mode (no Edge Function needed).
# "true" = calls Supabase Edge Function `ml-proxy` (deploy it + set OPENAI_API_KEY secret).
VITE_ENABLE_ML_FUNCTION="false"
